{
  "name": "cloudpilot",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered multi-cloud deploy and monitoring gateway",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run build -w @cloudpilot/core && npm run test --workspaces --if-present",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "typecheck": "npm run build -w @cloudpilot/core && npm run typecheck --workspaces --if-present",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "@babel/core": "7.29.6",
    "esbuild": "0.28.1",
    "hono": "4.12.25",
    "js-yaml": "4.2.0",
    "react-router": "6.30.4"
  },
  "dependencies": {}
}
