{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cloudpilot.dev/schemas/task-script/v1",
  "title": "CloudPilot Task Script v1",
  "description": "Schema for CloudPilot deployment task scripts",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "cloudpilot.dev/v1"
    },
    "kind": {
      "type": "string",
      "enum": ["DeploymentTask"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,61}[a-z0-9]$",
          "description": "lowercase alphanumeric and hyphens, 3-63 chars"
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "region", "environment", "dryRun", "approvalRequired", "resources"],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["aws", "gcp", "azure"]
        },
        "region": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "enum": ["development", "staging", "production"]
        },
        "dryRun": {
          "type": "boolean"
        },
        "approvalRequired": {
          "type": "boolean"
        },
        "resources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "name"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["container_service", "load_balancer", "storage_bucket", "database"]
              },
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]{0,61}[a-z0-9]?$"
              },
              "image": {
                "type": "string",
                "minLength": 1
              },
              "replicas": {
                "type": "integer",
                "minimum": 1,
                "maximum": 20
              },
              "cpu": {
                "type": "string",
                "pattern": "^[0-9]+(\\.[0-9]+)?$"
              },
              "memory": {
                "type": "string",
                "pattern": "^[0-9]+(Mi|Gi)$"
              }
            }
          }
        },
        "monitoring": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "alerts": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["metric", "threshold", "window"],
                "properties": {
                  "metric": {
                    "type": "string",
                    "minLength": 1
                  },
                  "threshold": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 100
                  },
                  "window": {
                    "type": "string",
                    "pattern": "^[0-9]+(s|m|h)$"
                  }
                }
              }
            }
          }
        },
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxMonthlyCostUsd": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "allowedResourceTypes": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["container_service", "load_balancer", "storage_bucket", "database"]
              }
            }
          }
        }
      }
    }
  }
}
