# CloudPilot Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Server
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_PATH=./data/cloudpilot.db

# AWS credentials (use IAM role or env vars, never hardcode)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1

# GCP credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=

# Azure credentials
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# Guardrails
MAX_CONCURRENT_TASKS=10
DEFAULT_MAX_MONTHLY_COST_USD=1000

# Approval
REQUIRE_APPROVAL_FOR_PRODUCTION=true
