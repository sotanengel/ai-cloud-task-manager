{
  "name": "@cloudpilot/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cloudpilot": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --watch dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudpilot/adapters": "*",
    "@cloudpilot/core": "*",
    "@fastify/cors": "^10.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastify": "^5.8.5",
    "pino": "^9.14.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "vitest": "^3.2.6"
  }
}
