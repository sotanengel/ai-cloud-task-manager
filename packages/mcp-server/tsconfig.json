{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "paths": {
      "@cloudpilot/core": ["../core/src/index.ts"],
      "@cloudpilot/adapters": ["../adapters/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../core" },
    { "path": "../adapters" }
  ]
}
